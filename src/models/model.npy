{
    "dataset": "mnist",
    "epochs": 5,
    "weight_decay": 0.0005,
    "batch_size": 32,
    "learning_rate": 0.001,
    "optimizer": "adam",
    "num_layers": 2,
    "hidden_size": [
        128,
        64
    ],
    "activation": "relu",
    "loss": "cross_entropy",
    "weight_init": "random",
    "wandb_project": "dl-assignment",
    "model_save_path": "models/model.npy"
}